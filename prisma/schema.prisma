generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Persona {
  id              String   @id @default(cuid())
  nombre          String
  camara          String
  departamento    String
  partido         String
  partidoSigla    String
  tipo            String
  cargoDirectiva  String?
  email           String?
  fotoUrl         String   @default("")
  activa          Boolean  @default(true)
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  menciones Mencion[]
  reportes  Reporte[]
}

model Medio {
  id            String   @id @default(cuid())
  nombre        String
  url           String
  tipo          String
  pais          String   @default("Bolivia")
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())

  menciones   Mencion[]
  capturaLogs CapturaLog[]
}

model Mencion {
  id                String   @id @default(cuid())
  personaId         String
  medioId           String
  titulo            String
  texto             String   @default("")
  url               String   @default("")
  fechaPublicacion  DateTime?
  fechaCaptura      DateTime @default(now())
  tipoMencion       String   @default("mencion_pasiva")
  sentimiento       String   @default("no_clasificado")
  temas             String   @default("")
  reach             Int      @default(0)
  verificado        Boolean  @default(false)
  fechaCreacion     DateTime @default(now())
  enlaceActivo      Boolean  @default(true)
  fechaVerificacion DateTime?
  textoCompleto     String   @default("")
  comentariosCount  Int      @default(0)
  comentariosResumen String  @default("")

  persona     Persona     @relation(fields: [personaId], references: [id])
  medio       Medio       @relation(fields: [medioId], references: [id])
  comentarios Comentario[]
}

model Reporte {
  id                     String   @id @default(cuid())
  tipo                   String
  personaId              String?
  fechaInicio            DateTime
  fechaFin               DateTime
  resumen                String   @default("")
  pdfUrl                 String   @default("")
  enviado                Boolean  @default(false)
  fechaEnvio             DateTime?
  totalMenciones         Int      @default(0)
  sentimientoPromedio    Float    @default(0)
  temasPrincipales       String   @default("")
  fechaCreacion          DateTime @default(now())
  totalComentarios       Int      @default(0)
  sentimientoComentarios String   @default("")
  enlacesRotos           Int      @default(0)

  persona Persona? @relation(fields: [personaId], references: [id])
}

model Comentario {
  id              String   @id @default(cuid())
  mencionId       String
  autor           String   @default("")
  texto           String
  sentimiento     String   @default("no_clasificado")
  fechaComentario DateTime?
  fechaCaptura    DateTime @default(now())

  mencion Mencion @relation(fields: [mencionId], references: [id], onDelete: Cascade)
}

model Suscriptor {
  id               String   @id @default(cuid())
  nombre           String
  email            String
  whatsapp         String?
  plan             String   @default("basico")
  fechaSuscripcion DateTime @default(now())
  activo           Boolean  @default(true)
}

model CapturaLog {
  id                   String   @id @default(cuid())
  fecha                DateTime @default(now())
  medioId              String
  totalArticulos       Int      @default(0)
  mencionesEncontradas Int      @default(0)
  exitosa              Boolean  @default(false)
  errores              String   @default("")

  medio Medio @relation(fields: [medioId], references: [id])
}
