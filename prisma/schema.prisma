generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Persona {
  id              String   @id @default(cuid())
  nombre          String
  camara          String
  departamento    String
  partido         String
  partidoSigla    String
  tipo            String
  cargoDirectiva  String?
  email           String?
  fotoUrl         String   @default("")
  activa          Boolean  @default(true)
  periodo         String   @default("2025-2030")
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  menciones Mencion[]
  reportes  Reporte[]
}

model Medio {
  id            String   @id @default(cuid())
  nombre        String
  url           String   @default("")
  tipo          String
  nivel         String   @default("1") // 1=corporativo, 2=regional, 3=alternativo, 4=redes, 5=repositorio
  departamento  String?  // para medios regionales
  plataformas   String   @default("") // "web,facebook,youtube,tiktok,x"
  notas         String   @default("")
  pais          String   @default("Bolivia")
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())

  menciones   Mencion[]
  capturaLogs CapturaLog[]
}

model EjeTematico {
  id            String   @id @default(cuid())
  nombre        String
  slug          String   @unique
  icono         String   @default("")
  color         String   @default("")
  descripcion   String   @default("")
  keywords      String   @default("") // palabras clave separadas por coma
  activo        Boolean  @default(true)
  orden         Int      @default(0)

  menciones MencionTema[]
}

model Mencion {
  id                String   @id @default(cuid())
  personaId         String
  medioId           String
  titulo            String
  texto             String   @default("")
  url               String   @default("")
  fechaPublicacion  DateTime?
  fechaCaptura      DateTime @default(now())
  tipoMencion       String   @default("mencion_pasiva")
  sentimiento       String   @default("no_clasificado")
  temas             String   @default("")
  reach             Int      @default(0)
  verificado        Boolean  @default(false)
  fechaCreacion     DateTime @default(now())
  enlaceActivo      Boolean  @default(true)
  fechaVerificacion DateTime?
  textoCompleto     String   @default("")
  comentariosCount  Int      @default(0)
  comentariosResumen String  @default("")

  persona       Persona          @relation(fields: [personaId], references: [id])
  medio         Medio            @relation(fields: [medioId], references: [id])
  comentarios   Comentario[]
  ejesTematicos MencionTema[]
}

model MencionTema {
  id            String   @id @default(cuid())
  mencionId     String
  ejeTematicoId String

  mencion     Mencion     @relation(fields: [mencionId], references: [id], onDelete: Cascade)
  ejeTematico EjeTematico @relation(fields: [ejeTematicoId], references: [id], onDelete: Cascade)

  @@unique([mencionId, ejeTematicoId])
}

model Reporte {
  id                     String   @id @default(cuid())
  tipo                   String   // "boletin_diario", "resumen_semanal", "informe_mensual", "ficha_legislador"
  personaId              String?
  fechaInicio            DateTime
  fechaFin               DateTime
  resumen                String   @default("")
  pdfUrl                 String   @default("")
  enviado                Boolean  @default(false)
  fechaEnvio             DateTime?
  totalMenciones         Int      @default(0)
  sentimientoPromedio    Float    @default(0)
  temasPrincipales       String   @default("")
  fechaCreacion          DateTime @default(now())
  totalComentarios       Int      @default(0)
  sentimientoComentarios String   @default("")
  enlacesRotos           Int      @default(0)
  contenido              String   @default("") // JSON del contenido estructurado del reporte
  clasificadores         String   @default("") // JSON con datos por clasificador

  persona Persona? @relation(fields: [personaId], references: [id])
}

model Comentario {
  id              String   @id @default(cuid())
  mencionId       String
  autor           String   @default("")
  texto           String
  sentimiento     String   @default("no_clasificado")
  fechaComentario DateTime?
  fechaCaptura    DateTime @default(now())

  mencion Mencion @relation(fields: [mencionId], references: [id], onDelete: Cascade)
}

model Suscriptor {
  id               String   @id @default(cuid())
  nombre           String
  email            String
  whatsapp         String?
  plan             String   @default("basico")
  fechaSuscripcion DateTime @default(now())
  activo           Boolean  @default(true)
}

model CapturaLog {
  id                   String   @id @default(cuid())
  fecha                DateTime @default(now())
  medioId              String
  nivel                String   @default("1")
  totalArticulos       Int      @default(0)
  mencionesEncontradas Int      @default(0)
  exitosa              Boolean  @default(false)
  errores              String   @default("")

  medio Medio @relation(fields: [medioId], references: [id])
}
