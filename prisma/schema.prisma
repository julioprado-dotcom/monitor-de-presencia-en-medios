generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Persona {
  id              String   @id @default(cuid())
  nombre          String
  camara          String
  departamento    String
  partido         String
  partidoSigla    String
  tipo            String
  cargoDirectiva  String?
  email           String?
  fotoUrl         String   @default("")
  activa          Boolean  @default(true)
  periodo         String   @default("2025-2030")
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  menciones Mencion[]
  reportes  Reporte[]
}

model Medio {
  id            String   @id @default(cuid())
  nombre        String
  url           String   @default("")
  tipo          String
  nivel         String   @default("1") // 1=corporativo, 2=regional, 3=alternativo, 4=redes, 5=repositorio
  departamento  String?  // para medios regionales
  plataformas   String   @default("") // "web,facebook,youtube,tiktok,x"
  notas         String   @default("")
  pais          String   @default("Bolivia")
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())

  menciones   Mencion[]
  capturaLogs CapturaLog[]
}

model EjeTematico {
  id            String   @id @default(cuid())
  parentId      String?
  nombre        String
  slug          String   @unique
  icono         String   @default("")
  color         String   @default("")
  descripcion   String   @default("")
  keywords      String   @default("")
  dimension     String   @default("")   // produccion, precio, conflicto, regulacion, infraestructura
  activo        Boolean  @default(true)
  orden         Int      @default(0)

  parent        EjeTematico?  @relation("EjeTematicoHierarchy", fields: [parentId], references: [id])
  children      EjeTematico[] @relation("EjeTematicoHierarchy")

  menciones MencionTema[]
}

model Mencion {
  id                String   @id @default(cuid())
  personaId         String
  medioId           String
  titulo            String
  texto             String   @default("")
  url               String   @default("")
  fechaPublicacion  DateTime?
  fechaCaptura      DateTime @default(now())
  tipoMencion       String   @default("mencion_pasiva")
  sentimiento       String   @default("no_clasificado")
  temas             String   @default("")
  reach             Int      @default(0)
  verificado        Boolean  @default(false)
  fechaCreacion     DateTime @default(now())
  enlaceActivo      Boolean  @default(true)
  fechaVerificacion DateTime?
  textoCompleto     String   @default("")
  comentariosCount  Int      @default(0)
  comentariosResumen String  @default("")

  persona       Persona          @relation(fields: [personaId], references: [id])
  medio         Medio            @relation(fields: [medioId], references: [id])
  comentarios   Comentario[]
  ejesTematicos MencionTema[]
}

model MencionTema {
  id            String   @id @default(cuid())
  mencionId     String
  ejeTematicoId String

  mencion     Mencion     @relation(fields: [mencionId], references: [id], onDelete: Cascade)
  ejeTematico EjeTematico @relation(fields: [ejeTematicoId], references: [id], onDelete: Cascade)

  @@unique([mencionId, ejeTematicoId])
}

model Reporte {
  id                     String   @id @default(cuid())
  tipo                   String   // ONION200: EL_TERMOMETRO, SALDO_DEL_DIA, EL_FOCO, EL_ESPECIALIZADO, EL_RADAR, EL_INFORME_CERRADO, VOZ_Y_VOTO, EL_HILO, ficha_legislador
  personaId              String?
  fechaInicio            DateTime
  fechaFin               DateTime
  resumen                String   @default("")
  pdfUrl                 String   @default("")
  enviado                Boolean  @default(false)
  fechaEnvio             DateTime?
  totalMenciones         Int      @default(0)
  sentimientoPromedio    Float    @default(0)
  temasPrincipales       String   @default("")
  fechaCreacion          DateTime @default(now())
  totalComentarios       Int      @default(0)
  sentimientoComentarios String   @default("")
  enlacesRotos           Int      @default(0)
  contenido              String   @default("") // JSON del contenido estructurado del reporte
  clasificadores         String   @default("") // JSON con datos por clasificador

  persona Persona? @relation(fields: [personaId], references: [id])
}

model Comentario {
  id              String   @id @default(cuid())
  mencionId       String
  autor           String   @default("")
  texto           String
  sentimiento     String   @default("no_clasificado")
  fechaComentario DateTime?
  fechaCaptura    DateTime @default(now())

  mencion Mencion @relation(fields: [mencionId], references: [id], onDelete: Cascade)
}

model Suscriptor {
  id               String   @id @default(cuid())
  nombre           String
  email            String
  whatsapp         String?
  plan             String   @default("basico")
  fechaSuscripcion DateTime @default(now())
  activo           Boolean  @default(true)
}

model CapturaLog {
  id                   String   @id @default(cuid())
  fecha                DateTime @default(now())
  medioId              String
  nivel                String   @default("1")
  totalArticulos       Int      @default(0)
  mencionesEncontradas Int      @default(0)
  exitosa              Boolean  @default(false)
  errores              String   @default("")

  medio Medio @relation(fields: [medioId], references: [id])
}

// ─── ONION200: Clientes y Contratos ──────────────────────────

model Cliente {
  id               String   @id @default(cuid())
  nombre           String
  nombreContacto   String   @default("")
  email            String
  telefono         String   @default("")
  whatsapp         String   @default("")
  organizacion     String   @default("")
  segmento         String   @default("otro") // "partido_politico", "movimiento_social", "ong", "embajada", "legislador", "medio", "academico", "otro"
  plan             String   @default("basico") // "basico", "avanzado", "institucional"
  estado           String   @default("activo") // "activo", "suspendido", "cancelado"
  parlamentarios   String   @default("") // JSON: lista de IDs de Persona asignadas al cliente
  ejesContratados  String   @default("") // JSON: lista de slugs de EjeTematico contratados
  notas            String   @default("")
  fechaCreacion    DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  contratos Contrato[]
}

model Contrato {
  id               String   @id @default(cuid())
  clienteId        String
  tipoProducto     String                       // ONION200: "EL_TERMOMETRO", "SALDO_DEL_DIA", "EL_FOCO", "EL_ESPECIALIZADO", etc.
  mediosAsignados  String   @default("")         // JSON: lista de IDs de Medio monitoreados para este contrato
  ejesTematicos    String   @default("")         // JSON: lista de slugs de EjeTematico incluidos
  parlamentarios   String   @default("")         // JSON: lista de IDs de Persona monitoreados
  frecuencia       String   @default("diario")   // "diario", "semanal", "quincenal", "mensual"
  formatoEntrega   String   @default("whatsapp") // "whatsapp", "email", "ambos"
  fechaInicio      DateTime
  fechaFin         DateTime?
  montoMensual     Float    @default(0)
  moneda           String   @default("Bs")
  estado           String   @default("activo")   // "activo", "pausado", "vencido", "cancelado"
  notas            String   @default("")
  fechaCreacion    DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  entregas Entrega[]
}

// ─── ONION200: Entregas (Tracking de boletines enviados) ─────────

model Entrega {
  id               String    @id @default(cuid())
  contratoId       String
  tipoBoletin      String                       // "EL_TERMOMETRO", "SALDO_DEL_DIA", etc.
  contenido        String    @default("")         // texto/HTML del boletín enviado
  fechaProgramada  DateTime?                     // fecha/hora programada
  fechaEnvio       DateTime?                     // fecha/hora real de envío
  estado           String    @default("pendiente") // "pendiente", "enviado", "fallido"
  canal            String    @default("whatsapp") // "whatsapp", "email", "web"
  destinatarios    String    @default("[]")       // JSON array de strings
  error            String?                       // null o "número inválido", etc.
  fechaCreacion    DateTime  @default(now())

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([contratoId])
  @@index([tipoBoletin])
  @@index([estado])
  @@index([fechaEnvio])
}

// ─── ONION200: Capa de Indicadores ───────────────────────────────

model Indicador {
  id              String   @id @default(cuid())
  nombre          String                       // "Tipo de Cambio Oficial"
  slug            String   @unique             // "tc-oficial-bcb"
  categoria       String                       // "monetario", "minero", "climatico", "economico", "hidrocarburos", "social"
  fuente          String                       // "Banco Central de Bolivia"
  url             String   @default("")         // URL de la fuente
  periodicidad    String   @default("diaria")   // "diaria", "semanal", "mensual"
  unidad          String   @default("")         // "Bs/USD", "USD/ton"
  formatoNumero   Int      @default(2)          // decimales a mostrar
  activo          Boolean  @default(true)
  orden           Int      @default(0)
  ejesTematicos   String   @default("")         // slugs de ejes donde aplica, separados por coma
  tier            Int      @default(1)           // 1=inmediato, 2=corto plazo, 3=mediano plazo
  notas           String   @default("")         // notas del capturador
  fechaCreacion   DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  valores IndicadorValor[]
}

model IndicadorValor {
  id            String   @id @default(cuid())
  indicadorId   String
  fecha         DateTime                      // fecha del dato (no de captura)
  valor         Float                         // valor numerico
  valorTexto    String   @default("")          // representacion textual si aplica
  confiable     Boolean  @default(true)        // false si la captura tuvo problemas
  fechaCaptura  DateTime @default(now())       // momento en que ONION200 capturo el dato
  metadata      String   @default("")          // JSON con info adicional

  indicador Indicador @relation(fields: [indicadorId], references: [id], onDelete: Cascade)

  @@index([indicadorId, fecha])
}

// ─── Autenticación (NextAuth v5) ──────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String?
  role          String    @default("admin") // "admin", "agente", "viewer"
  emailVerified DateTime?
  image         String?
  activo        Boolean   @default(true)
  fechaCreacion DateTime  @default(now())

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── ONION200: Suscriptores Gratuitos (El Radar) ──────────────────

model SuscriptorGratuito {
  id               String   @id @default(cuid())
  nombre           String   @default("")
  email            String   @unique
  whatsapp         String?
  origen           String   @default("landing") // "landing", "redes", "referido", "evento"
  activo           Boolean  @default(true)
  fechaSuscripcion DateTime @default(now())

  @@index([email])
}
