# ─── DECODEX Bolivia v0.8.0 — Variables de Entorno ─────────────────
# Copiar este archivo como .env y completar los valores.
# Las variables marcadas [REQUERIDO] son necesarias para producción.

# ─── Base de Datos ────────────────────────────────────────────────
DATABASE_URL="file:./db/custom.db"

# ─── Seguridad ────────────────────────────────────────────────────
# API key para proteger /api/seed (operaciones destructivas)
# Usar "dev" para modo desarrollo sin protección
# En producción, usar un valor fuerte como: openssl rand -hex 32
SEED_API_KEY="dev"

# Secret para NextAuth (obligatorio en producción)
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Módulo A1: WhatsApp Business API (Twilio) ────────────────────
# Sin estas variables, el módulo funciona en modo mock automático
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""

# ─── Módulo A2: Email Service (Resend) ────────────────────────────
# Sin esta variable, el módulo funciona en modo mock automático
RESEND_API_KEY=""
RESEND_FROM_EMAIL="DECODEX <noreply@decodex.bo>"

# ─── Módulo A4: PDF Generator (Puppeteer) ────────────────────────
# Puppeteer se instala por separado: npm install puppeteer
# Sin Puppeteer, el módulo genera HTML pero retorna buffer vacío
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium-browser"

# ─── Módulo A5: Cola de Trabajos (pg-boss) ──────────────────────
# Para producción con PostgreSQL (reemplaza SQLite)
# QUEUE_DATABASE_URL="postgresql://user:pass@localhost:5432/decodex"
# En modo mock (sin esta variable), usa cola en memoria

# ─── Módulo A3: Indicadores Económicos ──────────────────────────
# Funciona sin configuración (fuentes públicas + fallback)
# Cache TTL por defecto: 3600000ms (1 hora)
# INDICADORES_CACHE_TTL=3600000
# INDICADORES_TIMEOUT=10000

# ─── Z-AI SDK (Generación con IA) ────────────────────────────────
# Usado internamente por los generadores de producto (Equipo B)
# ZAI_API_KEY se configura automáticamente por el entorno

# ─── Aplicación ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
